# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/devmatch?schema=public"

# --- JWT ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- CORS ---
# Single origin:        CLIENT_ORIGIN="https://your-app.vercel.app"
# Multiple origins:     CLIENT_ORIGIN="https://your-app.vercel.app,http://localhost:5173"
# Allow all (dev only): CLIENT_ORIGIN="*"
# Vercel preview deploys (*.vercel.app) are auto-allowed if any listed origin
# ends in .vercel.app, so a single prod entry covers all branch previews.
CLIENT_ORIGIN="http://localhost:5173"
