# =============================================================
# DevMatch — root .gitignore (covers backend + frontend)
# =============================================================

# ----- Dependencies -----
**/node_modules/
**/.pnp
**/.pnp.js

# ----- Environment files (NEVER commit) -----
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
# .env.example IS committed (template only)
!**/.env.example

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- Build / dist outputs -----
**/dist/
**/build/
**/.next/
**/.nuxt/
**/.vite/
**/.turbo/
**/.parcel-cache/
**/out/

# ----- Test / coverage -----
**/coverage/
**/.nyc_output/
**/*.lcov

# ----- Prisma -----
# Keep schema + migration SQL committed; only ignore generated client.
**/prisma/migrations/dev.db*
**/.prisma/

# ----- IDE / editors -----
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
*~

# ----- OS noise -----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- Misc -----
*.tsbuildinfo
.eslintcache
.stylelintcache
*.pem
*.key
*.crt

# ----- Cursor / agent local state -----
.agents/
.cursor/
skills-lock.json
